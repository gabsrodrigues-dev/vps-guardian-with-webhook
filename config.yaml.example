# VPS Guardian - Configuração de Exemplo
# Copie para /opt/vps-guardian/guardian/config.yaml e ajuste conforme necessário

detection:
  # Termos suspeitos para detecção de mineradores
  # IMPORTANTE: NÃO adicione nomes de processos do kernel (kworker, ksoftirqd, etc.)
  # Apenas adicione nomes de MALWARE conhecidos
  suspicious_terms:
    # Mineradores conhecidos
    - xmrig
    - xmr-stak
    - monero
    - cpuminer
    - ethminer
    - cryptonight
    - ccminer
    - cgminer
    - bfgminer
    - minerd
    # Pools de mineração
    - stratum
    - pool.minexmr
    - supportxmr
    - nanopool
    - f2pool
    - hashvault
    - nicehash
    - minergate
    # Malware específico (nomes que imitam processos do kernel)
    - kworkerds
    - kdevtmpfsi
    - kinsing
    - perfctl
    - perfcc

  # Intervalo de varredura em segundos
  scan_interval_seconds: 5

  # Whitelist de processos de build/desenvolvimento
  # Estes processos podem executar de /tmp durante compilação sem serem bloqueados
  # O Guardian já tem uma lista interna (maturin, cargo, rustc, pip, npm, etc.)
  # Adicione outros se necessário:
  build_whitelist: []
  # Exemplo:
  # build_whitelist:
  #   - custom-compiler
  #   - my-build-tool

# Monitoramento de Recursos
# Premissa: Nenhum processo legítimo consome >75% por mais de 10 minutos
resources:
  # Threshold de CPU (porcentagem)
  cpu_threshold_percent: 75

  # Threshold de memória (porcentagem)
  memory_threshold_percent: 75

  # Notificar após N minutos de uso alto
  notify_after_minutes: 10

  # Matar processo após N minutos de uso alto
  kill_after_minutes: 20

  # Limite da VPS antes de bloqueio por abuso (referência)
  vps_abuse_limit_minutes: 90

  # Whitelist de processos (APENAS essenciais do sistema)
  whitelist:
    - dockerd
    - containerd
    - systemd
    - sshd
    - guardian.py
    - journald
    - networkd
    # Adicione outros processos legítimos se necessário

# Monitoramento de Rede
network:
  # Caminho para lista de mining pools
  mining_pools_list: /opt/vps-guardian/firewall/blocklists/mining-pools.txt

  # Caminho para lista de exit nodes TOR
  tor_nodes_list: /opt/vps-guardian/firewall/blocklists/tor-exit-nodes.txt

  # Portas suspeitas de mining
  suspicious_ports:
    - 3333
    - 8888
    - 14444
    - 5555
    - 7777

# Resposta a Incidentes
response:
  # Diretório para quarentena de binários suspeitos
  quarantine_dir: /var/quarantine

  # Arquivo de log
  log_file: /var/log/guardian.log

  # Notificações Telegram (opcional)
  telegram:
    enabled: false
    bot_token: "YOUR_BOT_TOKEN"  # Obtenha com @BotFather
    chat_id: "YOUR_CHAT_ID"      # Seu chat ID
    webhook_url: null             # Legacy, opcional

    # Recursos interativos (controle remoto via bot)
    interactive:
      enabled: true                   # Habilitar comandos e botões
      poll_interval_seconds: 2        # Intervalo de polling para comandos
      action_timeout_minutes: 30      # Timeout para ações pendentes

    # Segurança: IDs de usuários autorizados
    # Deixe vazio para permitir todos (não recomendado)
    allowed_user_ids: []
    # Exemplo:
    # allowed_user_ids:
    #   - 123456789
    #   - 987654321

  # Notificações via Webhook (opcional)
  # Envia notificações para qualquer endpoint HTTP via POST
  # Compatível com Slack, Discord, SIEM, dashboards customizados, etc.
  webhook:
    enabled: false
    url: "https://your-endpoint.example.com/guardian/webhook"

    # Token de autenticação (será enviado no header Authorization: Bearer <token>)
    # Se não configurado, um token será gerado automaticamente e exibido nos logs
    auth_token: null
    # Exemplo:
    # auth_token: "seu-token-secreto-aqui"

    # Timeout para requisições (segundos)
    timeout_seconds: 10

    # Número de tentativas em caso de falha
    retry_count: 2

    # ┌──────────────────────────────────────────────────────────┐
    # │           INSTRUÇÕES DE INTEGRAÇÃO                       │
    # ├──────────────────────────────────────────────────────────┤
    # │ Seu endpoint deve aceitar requisições POST com:          │
    # │                                                          │
    # │ HEADER:                                                  │
    # │   Content-Type: application/json                         │
    # │   Authorization: Bearer <auth_token>                     │
    # │                                                          │
    # │ BODY (JSON):                                             │
    # │ {                                                        │
    # │   "event": "threat_detected",                            │
    # │   "timestamp": "2026-01-24T12:00:00",                    │
    # │   "hostname": "my-vps",                                  │
    # │   "severity": "critical | warning | info",               │
    # │   "process": {"pid": 1234, "name": "xmrig"},            │
    # │   "reason": "Suspicious process: mining detected",       │
    # │   "action_taken": "killed+quarantined",                  │
    # │   "details": {"cpu_percent": 95.5},                      │
    # │   "forensics_path": "/var/lib/guardian/forensics/..."    │
    # │ }                                                        │
    # │                                                          │
    # │ EVENTOS POSSÍVEIS:                                       │
    # │   - threat_detected: Ameaça detectada (kill ou notify)   │
    # │   - container_warning: Container com CPU alta             │
    # │   - process_warning: Processo suspeito detectado          │
    # │   - test: Teste de conectividade                          │
    # │                                                          │
    # │ Retorne status 2xx para confirmar recebimento.           │
    # └──────────────────────────────────────────────────────────┘

# Verificação de Integridade
integrity:
  # Binários críticos para verificação de hash
  critical_binaries:
    - /usr/bin/ps
    - /usr/bin/top
    - /bin/ls
    - /usr/bin/lsof
    - /usr/bin/netstat
    - /usr/bin/ss
    - /usr/sbin/sshd
    - /usr/bin/find
    - /usr/bin/grep

  # Banco de dados de hashes
  hash_db: /var/lib/guardian/hashes.json

  # Detecção de rootkits
  rootkit_detection:
    enabled: true
    check_ld_preload: true
    check_hidden_uid0: true
    check_hugepages: true
    check_hidden_processes: true
    check_kernel_modules: true

# Monitoramento de Filesystem
filesystem:
  # Diretórios para monitorar (executáveis suspeitos)
  watch_dirs:
    - /tmp
    - /dev/shm
    - /var/tmp

  # Arquivos modificados nos últimos N minutos são considerados suspeitos
  max_file_age_minutes: 30

# Coleta de Evidências Forenses
forensics:
  # Habilitar coleta de evidências antes de matar processos
  enabled: true

  # Diretório para armazenar evidências forenses
  storage_dir: /var/lib/guardian/forensics

  # Tempo máximo para coletar evidências (segundos)
  max_collection_time_seconds: 2

  # Incluir variáveis de ambiente na coleta
  include_environ: true

  # Incluir arquivos abertos na coleta
  include_open_files: true

  # Retenção de evidências (dias)
  # Evidências mais antigas serão automaticamente removidas
  retention_days: 30

# Detecção de Mecanismos de Persistência
# Detecta cron jobs, systemd services, RC scripts e chaves SSH maliciosas
persistence:
  # Habilitar detecção de persistência
  enabled: true

  # Intervalo de varredura em segundos
  scan_interval_seconds: 60

  # Configuração de crontabs
  crontab:
    enabled: true
    check_system: true
    check_users: true
    system_paths:
      - /etc/crontab
    cron_d_path: /etc/cron.d
    user_crontabs_path: /var/spool/cron/crontabs
    periodic_paths:
      - /etc/cron.daily
      - /etc/cron.hourly
      - /etc/cron.weekly
      - /etc/cron.monthly

  # Configuração de systemd
  systemd:
    enabled: true
    service_path: /etc/systemd/system
    timer_path: /etc/systemd/system
    malicious_service_names:
      - bot.service
      - rondo.service
      - rsyslo.service
      - system-cleanup.service
      - perfctl.service
      - kdevtmpfsi.service
      - kinsing.service

  # Configuração de scripts RC
  rc_scripts:
    paths:
      - /etc/rc.local
      - /etc/init.d

  # Configuração de chaves SSH
  ssh_keys:
    enabled: true
    authorized_keys_paths:
      - /root/.ssh/authorized_keys
      - /home/*/.ssh/authorized_keys
    known_keys_db: /var/lib/guardian/known_ssh_keys.json
    alert_on_new: true

  # Whitelist para mecanismos legítimos do sistema
  # Use isso para evitar spam de webhook/logs com cron jobs e init scripts confiáveis
  allowed_paths:
    crontab:
      - /etc/cron.daily/apt-compat
      - /etc/cron.daily/google-chrome
      - /etc/cron.daily/rkhunter
      - /etc/cron.weekly/rkhunter
      - /etc/cron.d/staticroute
    rc_script:
      - /etc/init.d/plymouth
      - /etc/init.d/postfix
      - /etc/init.d/fail2ban
      - /etc/init.d/docker
      - /etc/init.d/x11-common
      - /etc/init.d/nginx
      - /etc/init.d/cron
      - /etc/init.d/kmod
      - /etc/init.d/rsync
      - /etc/init.d/iscsid
      - /etc/init.d/clamav-daemon
      - /etc/init.d/clamav-freshclam

  # Permite linhas específicas que parecem suspeitas, mas são legítimas no sistema
  allowed_content_patterns:
    rc_script:
      - 'RUNLEVEL="\$\(/sbin/runlevel \| cut -d " " -f 2\)"'

# Container Awareness
# Detecta se processos estão em containers e aplica ações específicas
containers:
  # Habilitar detecção de containers
  enabled: true

  # Ação a tomar quando ameaça detectada em container
  # Opções: 'stop' (parar container), 'alert' (apenas alertar)
  on_threat: stop

  # Whitelist de containers que nunca devem ser parados
  whitelist: []
  # Exemplo:
  # whitelist:
  #   - web-production
  #   - database

  # Monitoramento de Recursos de Containers
  # Monitora uso de CPU dos containers e para os que abusam dos recursos
  resource_monitoring:
    # Habilitar monitoramento de containers
    enabled: true

    # Threshold de CPU (porcentagem) para considerar abuso
    # Containers que usam >= 100% CPU continuamente são suspeitos
    cpu_threshold_percent: 100

    # Tempo (minutos) para enviar aviso via Telegram
    # Alerta precoce para containers com CPU alta
    warn_after_minutes: 5

    # Tempo (minutos) de CPU alta antes de parar o container
    # Containers com CPU >= threshold por este tempo serão parados
    kill_after_minutes: 15

    # Intervalo de verificação (segundos)
    check_interval_seconds: 60

    # Ação a tomar: 'stop' (parar gracefully) ou 'kill' (forçar parada)
    action: stop

    # Containers que NUNCA devem ser parados (regex patterns)
    # IMPORTANTE: Coolify e infraestrutura crítica devem estar aqui
    whitelist:
      - "coolify.*"           # Todos containers Coolify
      - "traefik.*"           # Proxy Traefik
      - ".*postgres.*"        # Bancos de dados
      - ".*redis.*"           # Cache Redis
      - ".*mysql.*"           # MySQL/MariaDB
      - ".*mariadb.*"

    # Whitelist por labels do Docker
    # Containers com estas labels nunca serão parados
    whitelist_labels:
      - "coolify.managed=true"
      - "guardian.ignore=true"

# Monitoramento Auditd (Opcional)
# Detecta processos de curta duração via auditd logs
auditd:
  # Habilitar monitoramento auditd (requer auditd instalado)
  enabled: false

  # Instalar regras auditd automaticamente
  install_rules: true

  # Caminho para arquivo de log do auditd
  log_path: /var/log/audit/audit.log
